{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        "$HOME/**"
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://localhost:11434/*"
        }
      ]
    },
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select"
  ]
}